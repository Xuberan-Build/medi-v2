{
  "buildCommand": "next build",
  "functions": {
    "api/health/route.ts": {
      "memory": 1024,
      "maxDuration": 10
    },
    "app/api/health/route.ts": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/**/route.ts": {
      "memory": 1024,
      "maxDuration": 10
    },
    "app/api/**/route.ts": {
      "memory": 1024,
      "maxDuration": 10
    },
    "app/(payload)/api/**/route.ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
